# MongoDB connection string (free tier: https://www.mongodb.com/atlas)
# e.g. mongodb+srv://user:pass@cluster0.xxxx.mongodb.net/zoopfi?retryWrites=true&w=majority
MONGODB_URI=

# Port the API listens on (Render/Railway set this automatically)
PORT=4000

# Optional: extra allowed CORS origins (comma-separated). *.vercel.app and
# localhost are allowed by default.
CORS_ORIGINS=
