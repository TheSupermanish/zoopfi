# Privy (auth + Stellar embedded wallet). Get one at https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=""

# Backend API base (Next.js proxies /api/backend -> this)
NEXT_PUBLIC_API_URL=https://YOUR_BACKEND_NGROK_URL

# Chain data layer: "mock" (default, fully simulated) or "stellar" (real testnet)
NEXT_PUBLIC_CHAIN_ADAPTER=mock

# Stellar network: "testnet" (default) or "mainnet"
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Required only for mainnet (SDF hosts no public mainnet RPC; use a provider)
# NEXT_PUBLIC_STELLAR_MAINNET_RPC_URL=

# Deployed contract IDs (optional; empty falls back to mock behavior)
# NEXT_PUBLIC_COUNTER_CONTRACT_ID=
# Zoopfi balance vault, live on Stellar testnet:
NEXT_PUBLIC_VAULT_CONTRACT_ID=CDZ22BGKBR4LH7NPO7BLZ2O6BWLQP6GNZTCR2PJWUOXMQUX4FVJP2UQR
